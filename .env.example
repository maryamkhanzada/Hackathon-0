# =============================================================================
# Personal AI Employee — Email MCP Server Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it's in .gitignore).

# --- Vault ---
VAULT_PATH=D:/Hackathon-0

# --- Gmail OAuth2 Credentials ---
# Get these from Google Cloud Console:
#   1. Go to https://console.cloud.google.com/
#   2. Enable Gmail API
#   3. Create OAuth 2.0 Desktop credentials
#   4. Use OAuth Playground (https://developers.google.com/oauthplayground)
#      to generate a refresh token with scope:
#      https://www.googleapis.com/auth/gmail.send

GMAIL_USER=your.email@gmail.com
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token

# --- Safety ---
# Set to "true" to log emails instead of actually sending them.
# Recommended for initial testing.
DRY_RUN=true
